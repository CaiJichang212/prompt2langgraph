      "outputs": {"value": {"state_key": "answer"}},
      "params": {}
    }
  ],
  "edges": [
    {"id": "unsupported_join", "source": "compose", "target": "finish", "kind": "join"}
  ],
  "policies": {},
  "metadata": {}
