{
  "schema_version": "0.1",
  "workflow_id": "fanout_with_join",
  "name": "Fanout with Join",
  "entrypoint": "split",
  "state_schema": {
    "input": {"items": {"type": "array", "item_type": {"type": "string"}}},
    "output": {"aggregated": {"type": "string"}},
    "channels": {
      "items": {"type": "array", "item_type": {"type": "string"}},
      "item": {"type": "string"},
      "results": {"type": "array", "item_type": {"type": "string"}},
      "aggregated": {"type": "string"}
    },
    "private": {},
    "reducers": {"results": "append"}
  },
  "nodes": [
    {
      "id": "split",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "items"}},
      "outputs": {"value": {"state_key": "items"}},
      "params": {}
    },
    {
      "id": "process",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "items"}},
      "outputs": {"value": {"state_key": "results"}},
      "params": {}
    },
    {
      "id": "process_b",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "items"}},
      "outputs": {"value": {"state_key": "results"}},
      "params": {}
    },
    {
      "id": "join_aggregate",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "results"}},
      "outputs": {"value": {"state_key": "aggregated"}},
      "params": {}
    }
  ],
  "edges": [
    {
      "id": "split_to_process",
      "source": "split",
      "target": "process",
      "kind": "linear"
    },
    {
      "id": "split_to_process_b",
      "source": "split",
      "target": "process_b",
      "kind": "linear"
    },
    {
      "id": "join_processed",
      "source": "process",
      "target": "join_aggregate",
      "kind": "join",
      "join_sources": ["process", "process_b"]
    }
  ],
  "policies": {},
  "metadata": {}
}
