{
  "schema_version": "0.1",
  "workflow_id": "join_edge_example",
  "name": "Join Edge Example",
  "entrypoint": "start",
  "state_schema": {
    "input": {"items": {"type": "array", "item_type": {"type": "string"}}},
    "output": {"results": {"type": "array", "item_type": {"type": "string"}}},
    "channels": {
      "items": {"type": "array", "item_type": {"type": "string"}},
      "item": {"type": "string"},
      "results": {"type": "array", "item_type": {"type": "string"}}
    },
    "private": {},
    "reducers": {"results": "append"}
  },
  "nodes": [
    {
      "id": "start",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "items"}},
      "outputs": {"value": {"state_key": "items"}},
      "params": {}
    },
    {
      "id": "process",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "item"}},
      "outputs": {"value": {"state_key": "results"}},
      "params": {}
    },
    {
      "id": "process_b",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "item"}},
      "outputs": {"value": {"state_key": "results"}},
      "params": {}
    },
    {
      "id": "aggregate",
      "kind": "transform",
      "executor": {"ref": "builtin.identity_transform", "type": "builtin"},
      "inputs": {"value": {"state_key": "results"}},
      "outputs": {"value": {"state_key": "results"}},
      "params": {}
    }
  ],
  "edges": [
    {
      "id": "fanout_to_process",
      "source": "start",
      "target": "process",
      "kind": "fanout",
      "map": {
        "items_state_key": "items",
        "item_state_key": "item",
        "result_state_key": "results"
      }
    },
    {
      "id": "fanout_to_process_b",
      "source": "start",
      "target": "process_b",
      "kind": "fanout",
      "map": {
        "items_state_key": "items",
        "item_state_key": "item",
        "result_state_key": "results"
      }
    },
    {
      "id": "join_results",
      "source": "process",
      "target": "aggregate",
      "kind": "join",
      "join_sources": ["process", "process_b"]
    }
  ],
  "policies": {},
  "metadata": {}
}
